# LLM
LLM_API_KEY=your-anthropic-api-key
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Embedding (local by default, zero cost)
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=

# Knowledge graph LLM for relation extraction (leave empty to reuse LLM_* settings)
# GRAPH_LLM_MODEL=claude-haiku-4-5-20251001
# GRAPH_LLM_API_KEY=

# Chunking
CHUNK_SIZE=2000
CHUNK_OVERLAP=256

# RAG
RAG_TOP_K=5
